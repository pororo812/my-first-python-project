def count_consonants(string):
    CONSONANTS = "bcdfhBCDFH"
    count = 0
    for char in string:
        if char in CONSONANTS:
            count += 1  #считает согласные,но здесь где-то ошибка

        return count


print(count_consonants("ddfufhuhhfcudffhud"))
