import json

# JSON-строка
json_text = '{"name": "Alex", "age": 25}'

# Превращаем JSON в словарь Python
user = json.loads(json_text)

print(user)
print(type(user))

# Берём значение по ключу
print(user["name"])
#выводит: {'name': 'Alex', 'age': 25}, <class 'dict'>, Alex
