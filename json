import json

user = {
    "name": "Alex",
    "age": 25
}

# Превращаем словарь Python в JSON-строку
json_text = json.dumps(user)

print(json_text)
print(type(json_text))
#выводит: {"name": "Alex", "age": 25}, <class 'str'>


