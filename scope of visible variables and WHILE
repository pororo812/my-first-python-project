import random

HEADS = "heads" #орел
TAILS = "tails" #решка
COIN_VALUES = [HEADS, TAILS]


def flip_coin():
    return random.choice(COIN_VALUES) #выдает рандом сторону

def play_martingale(*, starting_funds: int, min_bet: int, max_bet: int) -> int: #название игры и ставки 
    steeps_to_loose = 0 #шпокажет в итоге шаги до проигрыша
    current_funds = starting_funds #текущий бюджет равен бюджету в принте в конце
    current_bet = min_bet #текущая ставка равна мин ставке в принте

    while current_funds > 0:
        print("==========")
        steeps_to_loose += 1
        current_funds -= current_bet
        print(f"{current_funds=}, {current_bet=}")
        flipped_coin_value = flip_coin()
        if flipped_coin_value == HEADS:
            win = current_bet * 2
            print(f"{win=}")
            current_funds += win
            current_bet = min_bet
    else:
        print("lose")
        current_bet *= 2
        if current_bet > max_bet:
            current_bet = min_bet
        if current_bet > current_funds:
            current_bet = current_funds

    return steeps_to_loose

print(play_martingale(starting_funds=776, min_bet=100, max_bet=180))
